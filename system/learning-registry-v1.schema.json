{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Xixi learning registry v1",
  "type": "object",
  "required": ["schemaVersion", "owner", "candidates", "runs"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "owner": { "type": "string", "minLength": 1 },
    "candidates": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "title", "origin", "sourcePath", "sourceFingerprint", "contentFingerprint", "fields", "missingFields", "status"],
        "properties": {
          "status": {
            "enum": ["blocked_sensitive", "needs_completion", "ready_for_review", "needs_re_review", "project_only", "rejected", "approved_for_profile", "published"]
          }
        }
      }
    },
    "runs": { "type": "array" }
  }
}
